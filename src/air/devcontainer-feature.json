{
  "name": "Air",
  "version": "1.0.0",
  "id": "air",
  "description": "Live reload for Go apps",
  "options": {
    "version": {
      "type": "string",
      "proposals": [
        "latest"
      ],
      "default": "latest",
      "description": "Select the version you would like to install"
    }
  },
  "installsAfter": [
    "ghcr.io/devcontainers-extra/features/gh-release"
  ]
}
